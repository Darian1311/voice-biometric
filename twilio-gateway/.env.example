# ── Server ──
PORT=3000

# ── Redis (blacklist) ──
REDIS_URL=redis://127.0.0.1:6379
REDIS_BLACKLIST_KEY=scam:blacklist

# ── Twilio ──
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+40xxxxxxxxx
# Validează semnătura X-Twilio-Signature pe webhook-uri (true în producție)
VALIDATE_TWILIO=false
# URL public al acestui server (pentru validarea semnăturii), ex: https://abc.ngrok.io
PUBLIC_BASE_URL=

# ── Persoana protejată (bunica) ──
GRANDMA_NUMBER=+40xxxxxxxxx

# ── VAPI ──
VAPI_ASSISTANT_ID=your_assistant_id
VAPI_SIP_DOMAIN=sip.vapi.ai

# ── Detecție prefix suspect (E.164, separate prin virgulă) ──
SUSPECT_PREFIXES=+373,+44,+1,+234

# ── Scoring (voiceScore * VOICE_WEIGHT + keywordScore * KEYWORD_WEIGHT) ──
VOICE_WEIGHT=0.4
KEYWORD_WEIGHT=0.6
# Praguri pe scorul combinat 0-100: <GRAY=valid, GRAY..INVALID=gray_zone, >=INVALID=invalid
GRAY_ZONE_MIN=40
INVALID_MIN=70
